{
  mode: "client",

  connect: {
    timeout_ms: { router: 5000, peer: 0, client: 5000 },
    endpoints: [
      "tcp/localhost:7447"
    ],
    exit_on_failure: { router: false, peer: false, client: false },
    retry: {
      period_init_ms: 500,
      period_max_ms: 4000,
      period_increase_factor: 2,
    },
  },

  transport: {
    link: {
      tx: {
        batch_size: 16777215,
      },
      rx: {
        buffer_size: 16777216,
        max_message_size: 16777216,
      },
    },
  },
}
