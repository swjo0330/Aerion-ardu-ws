      <uri>file:///home/clrobur/lrauv_ws/build/lrauv_description/models/tethys_equipped</uri>
       <name>tethys</name>
    </include>
    -->


    <include>
  <uri>https://fuel.gazebosim.org/1.0/chapulina/models/Apartment</uri>
  <pose>0 30 0 0 0 -1.5708</pose>
    </include>

<!-- ================== FIRE / SMOKE (FOG GENERATOR - OFFICIAL) ================== -->
<include>
  <uri>https://fuel.ignitionrobotics.org/1.0/openrobotics/models/fog generator</uri>
  <name>fire_smoke_1</name>

  <!-- 🔥 화재 위치 (건물 위) -->
  <pose>0 25 5 0 -1.5707 0</pose>
</include>



<include>
  <uri>https://fuel.ignitionrobotics.org/1.0/openrobotics/models/fog generator</uri>
  <name>fire_smoke_2</name>

  <!-- 🔥 화재 위치 (건물 위) -->
  <pose>0 25 20 0 -1.5707 0</pose>
  <size>100 100 100</size>
</include>



